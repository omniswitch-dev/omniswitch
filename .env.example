# Built-in provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Custom provider credentials (referenced via api_key_env in config)
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
# AZURE_OPENAI_API_KEY=
# GUARDRAIL_API_KEY=

# Gateway runtime
OMNISWITCH_LISTEN=:8080
OMNISWITCH_DATA=.omniswitch
OMNISWITCH_CONFIG=examples/gateway-config.yaml
OMNISWITCH_AUTH=false
# Required for the first startup when OMNISWITCH_AUTH=true and the database has no keys.
# Keep this in a secret manager; it is hashed before storage and is never logged.
OMNISWITCH_BOOTSTRAP_API_KEY=
OMNISWITCH_BOOTSTRAP_WORKSPACE=
OMNISWITCH_BOOTSTRAP_ROLE=owner
OMNISWITCH_CACHE_THRESHOLD=0.95
OMNISWITCH_CACHE_TTL=24h
OMNISWITCH_CACHE_SCOPE=api_key
OMNISWITCH_LOG_PAYLOADS=false
OMNISWITCH_CORS_ORIGINS=
OMNISWITCH_GUARDRAIL_STREAM_BUFFER=true
OMNISWITCH_MAX_REQUEST_BYTES=10485760
OMNISWITCH_READ_HEADER_TIMEOUT=5s
OMNISWITCH_READ_TIMEOUT=30s
# Keep zero for streaming responses, or set an explicit limit for non-streaming-only deployments.
OMNISWITCH_WRITE_TIMEOUT=0s
OMNISWITCH_IDLE_TIMEOUT=60s
OMNISWITCH_CIRCUIT_BREAKER_FAILURES=5
OMNISWITCH_CIRCUIT_BREAKER_COOLDOWN=60s
OMNISWITCH_SHADOW_PROVIDER=

# Request quotas. Leave Redis empty for the process-local sliding window;
# configure Redis to coordinate quota enforcement across gateway replicas.
OMNISWITCH_RATE_LIMIT_REQUESTS=120
OMNISWITCH_RATE_LIMIT_WINDOW=1m
OMNISWITCH_RATE_LIMIT_REDIS_URL=
OMNISWITCH_RATE_LIMIT_PREFIX=omniswitch:ratelimit
OMNISWITCH_RATE_LIMIT_FAIL_OPEN=false

# OIDC/JWT workload identity. Local API keys remain valid during migration.
# Configuring a JWKS URL enables authentication automatically.
OMNISWITCH_OIDC_JWKS_URL=
OMNISWITCH_OIDC_ISSUER=
OMNISWITCH_OIDC_AUDIENCE=
OMNISWITCH_OIDC_ROLE_CLAIM=role
OMNISWITCH_OIDC_WORKSPACE_CLAIM=workspace_id
OMNISWITCH_OIDC_ORGANIZATION_CLAIM=organization_id
OMNISWITCH_OIDC_CACHE_TTL=5m

# Provider credential vault
# Set this before creating virtual provider keys so encrypted credentials survive restarts.
OMNISWITCH_VAULT_KEY=

# OpenTelemetry trace export
OMNISWITCH_OTEL_ENABLED=false
OMNISWITCH_OTEL_ENDPOINT=
OMNISWITCH_OTEL_SERVICE_NAME=omniswitch-gateway
OMNISWITCH_OTEL_HEADERS=
OMNISWITCH_OTEL_INSECURE=true
OMNISWITCH_OTEL_TIMEOUT=10s
OMNISWITCH_PROMETHEUS_ENABLED=true

# MCP policy gateway
OMNISWITCH_MCP_ENABLED=true
OMNISWITCH_MCP_POLICY=policies/production-delete.yaml
OMNISWITCH_MCP_UPSTREAM=http://127.0.0.1:8090/mcp
