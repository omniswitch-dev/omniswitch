# Provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Gateway runtime
SENTINEL_LISTEN=:8080
SENTINEL_DATA=.sentinel
SENTINEL_CONFIG=examples/gateway-config.yaml
SENTINEL_AUTH=false

# MCP policy gateway
SENTINEL_MCP_ENABLED=true
SENTINEL_MCP_POLICY=policies/production-delete.yaml
SENTINEL_MCP_UPSTREAM=http://127.0.0.1:8090/mcp
