# Built-in provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Custom provider credentials (referenced via api_key_env in config)
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
# AZURE_OPENAI_API_KEY=

# Gateway runtime
SENTINEL_LISTEN=:8080
SENTINEL_DATA=.sentinel
SENTINEL_CONFIG=examples/gateway-config.yaml
SENTINEL_AUTH=false
SENTINEL_CACHE_THRESHOLD=0.95
SENTINEL_CACHE_TTL=24h
SENTINEL_SHADOW_PROVIDER=

# Provider credential vault
# Set this before creating virtual provider keys so encrypted credentials survive restarts.
SENTINEL_VAULT_KEY=

# OpenTelemetry trace export
SENTINEL_OTEL_ENABLED=false
SENTINEL_OTEL_ENDPOINT=
SENTINEL_OTEL_SERVICE_NAME=sentinel-gateway
SENTINEL_OTEL_HEADERS=
SENTINEL_OTEL_INSECURE=true
SENTINEL_OTEL_TIMEOUT=10s

# MCP policy gateway
SENTINEL_MCP_ENABLED=true
SENTINEL_MCP_POLICY=policies/production-delete.yaml
SENTINEL_MCP_UPSTREAM=http://127.0.0.1:8090/mcp
